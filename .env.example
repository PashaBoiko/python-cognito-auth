# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_METHODS=["GET","POST","PUT","DELETE"]

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/python_auth

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# Cognito OAuth
COGNITO_URL=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_LOGIN_REDIRECT_URL=http://localhost:3000/auth/callback

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRATION_HOURS=24
